{
  "name": "prompt-to-canvas",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "description": "Agent skill for turning content into polished editable Excalidraw canvases.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 src/editor",
    "build": "vite build --config vite.config.mjs",
    "build:skill": "npm run build && rsync -a --delete src/static/ src/skills/prompt-to-canvas/assets/editor/",
    "preflight": "src/skills/prompt-to-canvas/scripts/preflight.sh",
    "preview": "vite preview --host 127.0.0.1 --outDir src/static"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "playwright": "^1.61.1"
  },
  "overrides": {
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "5.1.16"
    },
    "lodash-es": "4.18.1",
    "nanoid": "3.3.15"
  }
}
